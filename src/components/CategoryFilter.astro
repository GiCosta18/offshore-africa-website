---
import { CATEGORIES } from '../content.config';
const filters = ['All', ...CATEGORIES];
---

<div
  class="category-filter flex flex-wrap gap-2"
  role="group"
  aria-label="Filter articles by category"
>
  {
    filters.map((cat, i) => (
      <button
        type="button"
        class:list={[
          'filter-btn label rounded-sm border px-3.5 py-2 text-[0.7rem] transition-colors',
          i === 0
            ? 'border-navy bg-navy text-cream'
            : 'border-charcoal/20 bg-white text-navy hover:border-gold',
        ]}
        data-category={cat}
        aria-pressed={i === 0 ? 'true' : 'false'}
      >
        {cat}
      </button>
    ))
  }
</div>
