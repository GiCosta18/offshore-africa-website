---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

const issues = (await getCollection('issues')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const recentIssues = issues.slice(0, 5);

const benefits = [
  {
    title: 'The full monthly magazine',
    text: 'Every new edition delivered as a professionally produced PDF, straight to your inbox.',
  },
  {
    title: 'Exclusive analysis',
    text: 'Field reporting, interviews and insight you will not find anywhere else.',
  },
  {
    title: 'Ahead of the curve',
    text: 'Read the developments shaping African energy before they reach the mainstream.',
  },
  {
    title: 'Free, always',
    text: 'No paywall, no charge — just credible industry journalism in your inbox.',
  },
];
---

<Base
  title="Subscribe"
  description="Subscribe free to Offshore Africa Magazine and receive every monthly PDF edition delivered to your inbox."
>
  <!-- Hero -->
  <section class="bg-navy text-cream seismic-bg">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <p class="label flex items-center gap-3 text-xs text-gold">
        <span class="h-px w-10 bg-gold"></span>Free Subscription
      </p>
      <h1 class="mt-4 max-w-3xl font-serif text-4xl font-extrabold leading-tight sm:text-5xl">
        Get every issue of Offshore Africa Magazine
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-cream/75">
        Join industry professionals across the continent who receive our
        monthly PDF magazine — expert analysis of Africa's energy, mining, oil
        and gas sectors, delivered free to your inbox.
      </p>
    </div>
  </section>

  <!-- Why subscribe -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="label text-xs text-gold-dark">Why Subscribe</p>
    <h2 class="mt-1 font-serif text-3xl font-bold text-navy">
      What you get as a subscriber
    </h2>
    <div class="mt-9 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map((b) => (
          <div class="rounded-sm border border-charcoal/10 bg-white p-6 shadow-sm">
            <span class="block h-1 w-10 bg-gold" />
            <h3 class="mt-4 font-serif text-lg font-bold text-navy">{b.title}</h3>
            <p class="mt-2 text-sm text-charcoal/70">{b.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Signup form -->
  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <NewsletterSignup
      withName={true}
      heading="Start your free subscription"
      text="Enter your details below — we'll send a confirmation email to get you started."
    />
  </section>

  <!-- Recent issues -->
  <section class="border-t border-charcoal/10 bg-cream">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
      <p class="label text-xs text-gold-dark">Recent Editions</p>
      <h2 class="mt-1 font-serif text-3xl font-bold text-navy">
        Here's what subscribers receive
      </h2>
      <p class="mt-2 text-sm text-charcoal/70">
        Our most recent monthly editions — yours from the moment you subscribe.
      </p>
      <ul class="mt-7 divide-y divide-charcoal/10 border-y border-charcoal/10">
        {
          recentIssues.map((issue) => (
            <li class="flex items-center justify-between gap-4 py-4">
              <div class="flex items-center gap-4">
                <span class="label flex h-12 w-12 shrink-0 items-center justify-center rounded-sm bg-navy text-[0.6rem] text-gold">
                  OA
                </span>
                <span class="font-serif text-lg font-bold text-navy">
                  {issue.data.title}
                </span>
              </div>
              <a
                href={issue.data.pdf}
                target="_blank"
                rel="noopener noreferrer"
                class="label text-[0.7rem] text-gold-dark hover:text-navy"
              >
                Preview &rarr;
              </a>
            </li>
          ))
        }
      </ul>
      <a
        href="/issues/"
        class="label mt-6 inline-block text-xs text-navy hover:text-gold-dark"
        >Browse the full archive &rarr;</a
      >
    </div>
  </section>
</Base>
