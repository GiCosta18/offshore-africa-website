---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import { CONTACT } from '../consts';

const stats = [
  { figure: '10,000+', label: 'Industry professionals reached' },
  { figure: 'Monthly', label: 'Publication frequency' },
  { figure: 'Pan-African', label: 'Editorial & reader footprint' },
];

const formats = [
  {
    name: 'Full Page',
    text: 'A premium full-page placement within the magazine — maximum impact and brand presence.',
  },
  {
    name: 'Half Page',
    text: 'A cost-effective half-page unit, ideal for sustained campaigns and announcements.',
  },
  {
    name: 'Banner',
    text: 'Compact banner placements positioned alongside relevant editorial content.',
  },
  {
    name: 'Sponsored Article',
    text: 'Long-form sponsored content produced to editorial standard and clearly labelled.',
  },
];
---

<Base
  title="Advertise"
  description="Advertise with Offshore Africa Magazine and reach a focused audience of African energy, mining, oil and gas professionals."
>
  <!-- Hero -->
  <section class="bg-navy text-cream seismic-bg">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <p class="label flex items-center gap-3 text-xs text-gold">
        <span class="h-px w-10 bg-gold"></span>Advertise With Us
      </p>
      <h1 class="mt-4 max-w-3xl font-serif text-4xl font-extrabold leading-tight sm:text-5xl">
        Put your brand in front of African energy decision-makers
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-cream/75">
        Offshore Africa Magazine connects advertisers with a senior, focused
        readership across the continent's energy and mining value chain.
      </p>
    </div>
  </section>

  <!-- Audience stats -->
  <section class="border-b border-charcoal/10 bg-cream">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-14 sm:grid-cols-3 sm:px-6 lg:px-8">
      {
        stats.map((s) => (
          <div class="text-center">
            <p class="font-serif text-4xl font-extrabold text-navy">
              {s.figure}
            </p>
            <p class="label mt-2 text-xs text-gold-dark">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Ad formats -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="label text-xs text-gold-dark">Ad Formats</p>
    <h2 class="mt-1 font-serif text-3xl font-bold text-navy">
      Formats available
    </h2>
    <div class="mt-9 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        formats.map((f) => (
          <div class="rounded-sm border border-charcoal/10 bg-white p-6 shadow-sm">
            <span class="block h-1 w-10 bg-gold" />
            <h3 class="mt-4 font-serif text-xl font-bold text-navy">{f.name}</h3>
            <p class="mt-2 text-sm text-charcoal/70">{f.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Rate card -->
  <section class="border-y border-charcoal/10 bg-cream">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
      <p class="label text-xs text-gold-dark">Rate Card</p>
      <h2 class="mt-1 font-serif text-3xl font-bold text-navy">Advertising rates</h2>
      <div class="mt-7 overflow-hidden rounded-sm border border-charcoal/10 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-navy text-cream">
            <tr>
              <th class="label px-5 py-3 text-[0.7rem]">Format</th>
              <th class="label px-5 py-3 text-[0.7rem]">Specification</th>
              <th class="label px-5 py-3 text-[0.7rem]">Rate</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-charcoal/10">
            {
              formats.map((f) => (
                <tr>
                  <td class="px-5 py-3 font-semibold text-navy">{f.name}</td>
                  <td class="px-5 py-3 text-charcoal/70">Print &amp; digital edition</td>
                  <td class="px-5 py-3 text-charcoal/50">Rate on request</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-charcoal/55">
        Indicative rate card — current rates, multi-issue packages and bespoke
        sponsorship options are available on request.
      </p>
    </div>
  </section>

  <!-- Enquiry form -->
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="label text-xs text-gold-dark">Advertising Enquiry</p>
    <h2 class="mt-1 font-serif text-3xl font-bold text-navy">
      Request the full media kit
    </h2>
    <p class="mt-2 text-sm text-charcoal/70">
      Send us a few details and our team will respond with rates, specifications
      and availability. You can also email
      <a href={`mailto:${CONTACT.email}`} class="text-gold-dark underline">
        {CONTACT.email}</a
      > directly.
    </p>
    <div class="mt-6">
      <ContactForm defaultSubject="Advertising" />
    </div>
  </section>
</Base>
