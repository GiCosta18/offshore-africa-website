# Public newsletter signup endpoint (magazine mailer API).
# The PUBLIC_ prefix is required so Astro exposes it to client-side code.
# Update this to the live endpoint once the mailer is deployed, e.g.:
#   PUBLIC_SIGNUP_API_URL=https://api.offshoreafricamagazine.net/public/signup
PUBLIC_SIGNUP_API_URL=http://localhost:3000/public/signup

# Web3Forms access key for the contact form.
# Get a free key in ~30 seconds at https://web3forms.com (just enter your email).
PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_KEY
